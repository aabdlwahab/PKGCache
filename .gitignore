# The cache state lives in its OWN git + DVC repo under caches/ (separate from
# this code repo): the DVC pointers, manifests, .dvc store and the cached bytes
# all belong to that repo, never to the code history. Ignore the whole tree —
# including its nested .git/.dvc — so checkpoints can never touch code history.
/caches/

# Host-specific container uid/gid mapping (see .env.example). Never committed.
/.env

# Project registry: each extra project's allocated ports are host-specific state
# (managed by the control UI), not source. pkgcache + webui share this file; it is
# (re)created as projects are created.
/config/projects.json

# Shuttle staging area (fixed export/import dirs) — local transfer artifacts.
/shuttle/
*.bundle
/dvcstore/

# Python bytecode
__pycache__/
*.pyc

# TLS material (scripts/gen-certs.sh). Private keys never leave this host; the
# CA cert is shareable (carry it across the gap, install on build hosts).
/certs/*.key
/certs/*.srl
!/certs/ca.crt
